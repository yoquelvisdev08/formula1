---
interface Props {
  active?: "dashboard" | "live" | "drivers" | "standings" | "calendar";
}

const { active } = Astro.props;

const links = [
  { id: "dashboard", label: "Apex", href: "/" },
  { id: "live", label: "Live Timing", href: "/live" },
  { id: "drivers", label: "Drivers & Teams", href: "/drivers" },
  { id: "standings", label: "Standings", href: "/standings" },
  { id: "calendar", label: "Calendar", href: "/calendar" },
] as const;
---

<header class="sticky top-0 z-40 border-b border-track/70 bg-bg/80 backdrop-blur-xl">
  <div class="mx-auto flex w-full max-w-[1440px] items-center justify-between px-4 md:px-16 h-16">
    <a href="/" class="group flex items-center gap-3">
      <span class="relative flex h-9 w-9 items-center justify-center bg-racing clip-chamfer-tr">
        <span class="font-display font-extrabold text-bg text-lg leading-none">F1</span>
        <span class="absolute -right-1 -bottom-1 h-2 w-2 bg-electric"></span>
      </span>
      <span class="flex flex-col leading-tight">
        <span class="font-display text-lg font-bold tracking-tight">VELOCITY <span class="text-racing">PRIME</span></span>
        <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-fg-subtle">the paddock, decoded</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {links.map((link) => {
        const isActive = active === link.id;
        return (
          <a
            href={link.href}
            class:list={[
              "relative px-4 py-2 font-mono text-xs uppercase tracking-[0.2em] transition-colors",
              isActive ? "text-fg" : "text-fg-subtle hover:text-fg",
            ]}
          >
            {link.label}
            {isActive && (
              <span class="absolute left-2 right-2 -bottom-px h-[2px] bg-racing"></span>
            )}
          </a>
        );
      })}
    </nav>

    <a
      href="/live"
      class="hidden md:inline-flex items-center gap-2 bg-surface-low border border-track px-3 py-2 font-mono text-xs uppercase tracking-[0.2em] text-fg hover:bg-racing hover:text-white hover:border-racing transition-colors clip-chamfer-tr"
    >
      <span class="relative flex h-2 w-2">
        <span class="absolute inset-0 bg-racing pulse-live"></span>
      </span>
      Live
    </a>

    <button
      class="md:hidden inline-flex h-9 w-9 items-center justify-center border border-track bg-surface-low"
      aria-label="Open menu"
      id="mobile-menu-toggle"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 6h18M3 12h18M3 18h18" />
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden border-t border-track bg-surface">
    <div class="flex flex-col">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "px-4 py-3 font-mono text-xs uppercase tracking-[0.2em] border-b border-track/50",
            active === link.id ? "bg-racing text-white" : "text-fg-subtle",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
