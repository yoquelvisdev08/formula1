---
import { teamHex } from "../lib/format";

interface Props {
  driver: {
    driver_number: number;
    name_acronym: string;
    full_name?: string | null;
    broadcast_name?: string | null;
    team_colour: string;
    headshot_url?: string | null;
  };
  size?: "sm" | "md" | "lg";
  showName?: boolean;
  class?: string;
}

const { driver, size = "md", showName = false, class: className = "" } = Astro.props;
const color = teamHex(driver.team_colour);
const sizes = {
  sm: { box: "h-9 w-9", text: "text-xs", num: "text-[9px]" },
  md: { box: "h-12 w-12", text: "text-sm", num: "text-[10px]" },
  lg: { box: "h-16 w-16", text: "text-base", num: "text-xs" },
};
const s = sizes[size];
---

<div class:list={["flex items-center gap-3", className]}>
  <div
    class:list={["relative shrink-0 bg-surface-low border-2 overflow-hidden", s.box]}
    style={`border-color: ${color}`}
  >
    {driver.headshot_url ? (
      <img
        src={driver.headshot_url}
        alt={driver.full_name ?? driver.name_acronym}
        loading="lazy"
        class="absolute inset-0 h-full w-full object-cover object-top"
      />
    ) : (
      <div class="absolute inset-0 flex items-center justify-center font-display font-bold" style={`color: ${color}`}>
        {driver.name_acronym}
      </div>
    )}
    <span
      class:list={["absolute bottom-0 left-0 right-0 text-center font-mono font-bold text-white px-0.5 leading-tight", s.num]}
      style={`background: ${color}`}
    >
      #{driver.driver_number}
    </span>
  </div>
  {showName && (
    <div class="min-w-0">
      <div class:list={["font-display font-bold uppercase tracking-tight truncate", s.text]}>
        {driver.broadcast_name ?? driver.full_name}
      </div>
      <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-fg-subtle">
        {driver.name_acronym}
      </div>
    </div>
  )}
</div>
