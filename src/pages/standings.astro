---
import Base from "../layouts/Base.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import Skeleton from "../components/ui/Skeleton.astro";
import ErrorState from "../components/ErrorState.astro";
---

<Base title="Championship Standings · Velocity Prime" active="standings">
  <section class="pt-10 pb-8">
    <div class="flex items-center gap-2 mb-2">
      <span class="h-3 w-[2px] bg-racing"></span>
      <span class="font-mono text-[11px] uppercase tracking-[0.3em] text-racing">Championship</span>
    </div>
    <h1 class="font-display text-5xl md:text-7xl font-extrabold uppercase tracking-tight leading-none">
      The <span class="text-racing">Title</span> Fight
    </h1>
    <p class="mt-4 text-base text-fg-muted max-w-2xl">
      Who's on for the crown. Who's clawing back. Live standings for drivers and
      constructors — the only numbers that matter come Abu Dhabi.
    </p>
  </section>

  <section class="grid gap-10 lg:grid-cols-[2fr_1fr] mb-12 reveal">
    <div>
      <SectionHeader eyebrow="Drivers" title="Drivers' Championship" description="Points, wins, podium-finishing teams." />
      <div id="driver-standings">
        <Skeleton rows={10} height="h-14" />
      </div>
    </div>
    <div>
      <SectionHeader eyebrow="Constructors" title="Constructors' Cup" />
      <div id="constructor-standings">
        <Skeleton rows={8} height="h-16" />
      </div>
    </div>
  </section>

  <div id="standings-error" class="hidden"><ErrorState /></div>
</Base>

<script>
  import { getDriverStandings, getConstructorStandings, teamColourFor } from "../lib/jolpica";
  import { swr } from "../lib/cache";
  import { staggerReveal, countUp } from "../lib/anim";
  import { photoMarkup, teamLogoMarkup, hydratePhotos } from "../lib/wiki";
  import type { DriverStanding, ConstructorStanding } from "../lib/jolpica";

  function renderDrivers(standings: DriverStanding[]): void {
    const wrap = document.getElementById("driver-standings");
    if (!wrap) return;
    if (!standings.length) {
      wrap.innerHTML = `<p class="text-sm text-fg-subtle font-mono">Standings not available yet.</p>`;
      return;
    }
    const max = Number(standings[0].points) || 1;
    wrap.innerHTML = "";
    for (const s of standings) {
      const team = s.Constructors[0];
      const color = teamColourFor(team?.constructorId);
      const points = Number(s.points);
      const wins = Number(s.wins);
      const fillPct = (points / max) * 100;
      const isLeader = s.position === "1";
      const initials = (s.Driver.code ?? `${s.Driver.givenName.charAt(0)}${s.Driver.familyName.charAt(0)}`).toUpperCase();
      const a = document.createElement("a");
      a.href = `/drivers/${s.Driver.driverId}`;
      a.className = "reveal lift racing-stripe relative flex items-center gap-4 border-b border-track/40 py-4 px-3 hover:bg-surface-low transition-colors";
      a.innerHTML = `
        <span class="w-10 font-display text-3xl font-extrabold tabular-nums ${isLeader ? "" : "text-fg-muted"}" style="${isLeader ? `color:${color}` : ""}">${s.position}</span>
        ${photoMarkup({ wikiUrl: s.Driver.url, initials, color, size: "md" })}
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-3 mb-1.5 flex-wrap">
            <span class="font-display font-bold text-lg uppercase tracking-tight truncate">${s.Driver.givenName} ${s.Driver.familyName}</span>
            <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-fg-subtle">${s.Driver.code ?? s.Driver.familyName.slice(0, 3).toUpperCase()}</span>
            ${wins > 0 ? `<span class="inline-flex items-center gap-1 font-mono text-[10px] uppercase tracking-[0.2em] text-warning"><span>★</span>${wins} win${wins === 1 ? "" : "s"}</span>` : ""}
          </div>
          <div class="flex items-center gap-3">
            <div class="flex-1 h-1.5 bg-surface-low border border-track/40 overflow-hidden">
              <div class="h-full" style="width:${fillPct.toFixed(1)}%; background:${color}; transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);"></div>
            </div>
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] truncate" style="color:${color}">${team?.name ?? "—"}</span>
          </div>
        </div>
        <div class="text-right shrink-0">
          <div class="font-display text-3xl font-extrabold tabular-nums points-target" data-points="${points}">0</div>
          <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-fg-subtle">points</div>
        </div>
      `;
      wrap.appendChild(a);
    }
    staggerReveal(wrap.querySelectorAll<HTMLElement>(".reveal"), { delay: 80, stagger: 60 });
    setTimeout(() => {
      wrap.querySelectorAll<HTMLElement>(".points-target").forEach((el) => {
        const target = Number(el.dataset.points);
        countUp(el, target, { duration: 900 });
      });
    }, 200);
    hydratePhotos(wrap);
  }

  function renderConstructors(standings: ConstructorStanding[]): void {
    const wrap = document.getElementById("constructor-standings");
    if (!wrap) return;
    if (!standings.length) {
      wrap.innerHTML = `<p class="text-sm text-fg-subtle font-mono">Standings not available yet.</p>`;
      return;
    }
    const max = Number(standings[0].points) || 1;
    wrap.innerHTML = "";
    for (const s of standings) {
      const color = teamColourFor(s.Constructor.constructorId);
      const logo = teamLogoMarkup({ wikiUrl: s.Constructor.url, name: s.Constructor.name, color, height: "2rem" });
      const points = Number(s.points);
      const fillPct = (points / max) * 100;
      const isLeader = s.position === "1";
      const div = document.createElement("div");
      div.className = "reveal lift relative border border-track bg-carbon p-4 mb-3 clip-chamfer-tr";
      div.innerHTML = `
        <div class="absolute left-0 top-0 bottom-0 w-[3px]" style="background:${color}"></div>
        <div class="flex items-center justify-between mb-2 gap-3">
          <div class="flex items-center gap-3 min-w-0">
            <span class="font-display text-2xl font-extrabold tabular-nums" style="color:${color}">${s.position}</span>
            ${logo}
            <span class="font-display font-bold text-lg uppercase tracking-tight truncate" style="color:${color}">${s.Constructor.name}</span>
          </div>
          <div class="text-right shrink-0">
            <div class="font-display text-xl font-extrabold tabular-nums constructor-points" data-points="${points}">0</div>
            <div class="font-mono text-[9px] uppercase tracking-[0.2em] text-fg-subtle">${isLeader ? "leader" : "pts"}</div>
          </div>
        </div>
        <div class="h-1 bg-surface-low border border-track/40 overflow-hidden">
          <div class="h-full" style="width:${fillPct.toFixed(1)}%; background:${color}; transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);"></div>
        </div>
      `;
      wrap.appendChild(div);
    }
    staggerReveal(wrap.querySelectorAll<HTMLElement>(".reveal"), { delay: 80, stagger: 80 });
    setTimeout(() => {
      wrap.querySelectorAll<HTMLElement>(".constructor-points").forEach((el) => {
        const target = Number(el.dataset.points);
        countUp(el, target, { duration: 900 });
      });
    }, 200);
  }

  async function load(): Promise<void> {
    const errorBox = document.getElementById("standings-error");
    try {
      await Promise.allSettled([
        swr(() => getDriverStandings("current"), {
          key: "standings:drivers",
          onCached: renderDrivers,
          onFresh: renderDrivers,
          onError: (err) => console.warn("[standings] drivers failed", err),
        }),
        swr(() => getConstructorStandings("current"), {
          key: "standings:constructors",
          onCached: renderConstructors,
          onFresh: renderConstructors,
          onError: (err) => console.warn("[standings] constructors failed", err),
        }),
      ]);
      // Reveal root sections that hold `reveal` directly — these are NOT
      // covered by the per-render stagger inside each panel.
      staggerReveal(document.querySelectorAll<HTMLElement>(".reveal"), { delay: 0, stagger: 60 });
    } catch (err) {
      console.error("[standings] failed", err);
      errorBox?.classList.remove("hidden");
    }
  }

  load();
</script>
